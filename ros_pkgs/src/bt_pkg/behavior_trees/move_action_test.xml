<?xml version="1.0" encoding="UTF-8"?>
<!--
  move_action_test.xml — 1차 통합 검증용 최소 트리.

  목적: bt_pkg MoveAction → /run_hybrid_planning → MoveIt → Isaac 팔 이동
        경로만 고립 검증. VGN/YOLO/Qwen/Gripper 전부 불필요.

  트리거: /world_map_result (target centroid 있는 JSON)
          /grasp_candidates ({"candidates": []} — 빈거)
  → ParseScene가 candidates 비었으니 centroid fallback 으로
    아래보는(down-pointing) grasp pose 생성 → MoveAction이 전송.

  실제 통합(1b)에서는 위 두 트리거 publish 자리에
  g-sam → qwen → mask_projection 체인이 그대로 들어가면 됨.

  실행:
    ros2 run bt_pkg bt_executor_node --ros-args \
      -p tree_file:=<이 파일 절대경로>
-->
<root BTCPP_format="4">
  <BehaviorTree ID="MoveActionTest">
    <Sequence name="world_map_to_moveit">
      <WaitForScene/>
      <ParseScene/>
      <SelectGraspCandidate/>
      <!-- raw centroid("grasp_pose") 대신 그 위 pre_grasp_z_offset(기본 0.12m)
           만큼 띄운 pre_grasp_pose를 노림 → 책상 바닥 충돌/IK 실패 회피.
           speed: replan 데모에서 multi-link arm sweep 폭을 줄여 local 5 Hz
           tick(200ms) 당 cartesian 이동량 4mm으로 제한 — collision_object
           안으로 여러 link가 한 번에 깊이 들어가는 것을 막는다. -->
      <MoveAction pose_key="pre_grasp_pose" speed="0.01"/>
    </Sequence>
  </BehaviorTree>
</root>
